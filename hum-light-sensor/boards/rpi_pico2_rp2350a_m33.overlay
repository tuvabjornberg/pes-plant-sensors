/ {
    chosen {
        zephyr,console = &cdc_acm_uart0;
    };

    aliases {
        alert-gpio = &alert_pin_node;
    };

    gpio_outputs {
        compatible = "gpio-leds";       /* gives DTC the binding it needs */
        alert_pin_node: alert_pin_node {
            gpios = <&gpio0 15 0>;      /* 0 = GPIO_ACTIVE_HIGH */
        };
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

&i2c0 {
    status = "okay";
};